# Servidor MCP local
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_PROGRESS_PATH=.data/student_progress.json
MCP_PROGRESS_BACKEND=local
MCP_CONTENT_AUTHORING_PATH=.data/content_authoring.json
FIRESTORE_PROGRESS_COLLECTION=student_progress

# Use "mock" para arrancar sin credenciales. Cambie a "gemini" para Google AI Studio.
APP_SESSIONS_BACKEND=local
APP_SESSIONS_PATH=.data/sessions.json
APP_SESSION_RETENTION_DAYS=365
FIRESTORE_SESSIONS_COLLECTION=learning_sessions
# Configure el mismo secreto en ambos servicios; déjelo vacío para deshabilitar autoría.
APP_AUTHORING_TOKEN=
MCP_AUTHORING_TOKEN=
MODEL_PROVIDER=mock
MODEL_TIMEOUT_SECONDS=20
MCP_SERVER_URL=http://localhost:8001/mcp/
MCP_AUTHORING_URL=http://localhost:8001/admin
MCP_USE_LOCAL_ADAPTER=true
MCP_TIMEOUT_SECONDS=5
MCP_AUTH_AUDIENCE=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Kore
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Adaptador opcional de Microsoft Foundry (Fase 6)
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=
FOUNDRY_SCOPE=https://ai.azure.com/.default
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
